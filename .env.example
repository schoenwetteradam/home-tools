# Copy this file to .env and fill in your own values, then run install.sh (or `docker compose up -d`).

# Timezone, e.g. America/Chicago
TZ=America/Chicago

# Static/reserved LAN IP of the Raspberry Pi itself (set a DHCP reservation on your router first).
# Pi-hole needs to know its own address to serve DNS correctly on the LAN.
PI_STATIC_IP=192.168.1.10

# Password for the Pi-hole admin web UI (http://<pi-ip>:8080/admin). Pick your own.
PIHOLE_WEBPASSWORD=changeme

# Eufy Security cloud account (used by the eufy-security-ws bridge; Home Assistant's
# Eufy Security custom integration talks to this bridge, not to Eufy's cloud directly).
# Use a dedicated Eufy account if possible, since some accounts get logged out elsewhere on login.
EUFY_USERNAME=you@example.com
EUFY_PASSWORD=changeme
EUFY_COUNTRY=US
